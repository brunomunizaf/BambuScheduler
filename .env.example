# Printer LAN config (find on the printer's display)
# IP: Settings > Network
# Access Code: Settings > LAN
# Serial Number: Settings > Device Info (or on the printer's sticker)
PRINTER_IP=192.168.1.100
PRINTER_ACCESS_CODE=12345678
PRINTER_SERIAL=01A00A000000000
# Optional: custom name (falls back to model name from printer)
PRINTER_NAME=
